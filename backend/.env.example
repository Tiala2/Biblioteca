# =========================
# Library API - Environment
# =========================
# Copy this file to .env and adjust values.

# Keep project/container names stable
COMPOSE_PROJECT_NAME=backend

# Core app
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Postgres container
POSTGRES_DB=library
POSTGRES_USER=library
POSTGRES_PASSWORD=library

# API datasource
DB_URL=jdbc:postgresql://library:5432/library
DB_USERNAME=library
DB_PASSWORD=library

# Auth and storage
JWT_SECRET=CHANGE_ME_LONG_SECRET
JWT_EXPIRATION_MILIS=86400000
MINIO_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# Upload
MINIO_MAX_SIZE_MB=50
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=50MB

# Alerts
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_FROM=no-reply@library.local

# Open catalog cache policy
OPEN_CACHE_TTL_DAYS=60
OPEN_CACHE_CLEANUP_ENABLED=true
OPEN_CACHE_CLEANUP_CRON=0 15 3 * * *

# ============================================
# Email provider mode A (local free dev test)
# ============================================
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false

# ============================================
# Email provider mode B (Brevo free production)
# ============================================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_BREVO_SMTP_LOGIN
MAIL_PASSWORD=CHANGE_ME_BREVO_SMTP_KEY
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
ALERT_EMAIL_FROM=CHANGE_ME_VALIDATED_SENDER@yourdomain.com
